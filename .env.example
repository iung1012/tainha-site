# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Secret (gere uma string aleatória longa)
JWT_SECRET=sua_chave_secreta_muito_longa_aqui

# Syncpay (gateway de PIX)
SYNCPAY_API_KEY=sua_api_key_syncpay
SYNCPAY_BASE_URL=https://api.syncpay.com.br/v1
SYNCPAY_WEBHOOK_SECRET=seu_webhook_secret_syncpay

# Resend (email)
RESEND_API_KEY=re_sua_api_key_resend
EMAIL_FROM=Tainha do Mar <noreply@seudominio.com>

# App
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://seusite.railway.app

# Admin inicial (criado automaticamente na primeira execução)
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=suasenhaadmin123
ADMIN_NAME=Administrador
